{
  "__comment": "The production PreToolUse hook is now live in .claude/settings.json as of v23.8.14 (ADR-051 Phase 5b). This file documents the shape for reference and for installing the gate in a fresh VoidForge project.",

  "production_hook": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/surfer-gate/check.sh"
          }
        ]
      }
    ]
  },

  "validation_phase_5a_diagnostic_only": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/surfer-gate/validate.sh"
          }
        ]
      }
    ]
  }
}
